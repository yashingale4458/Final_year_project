# AntiCheat Vision System - Environment Variables
# Copy this file to .env and fill in your values

# ==================== Detection Settings ====================

# Head pose detection threshold (degrees) - yaw angle to flag as "looking sideways"
YAW_THRESHOLD=15.0

# Duration (seconds) before alert triggers for head pose
LOOK_DURATION=0.5

# Proximity detection threshold (pixels) - distance between students
PROXIMITY_PIX=150

# Duration (seconds) before proximity alert triggers
PROXIMITY_DURATION=2.0

# Frame skip interval - process every Nth frame (higher = faster, less accurate)
FRAME_SKIP=5

# Minimum confidence threshold for YOLO detection
CONFIDENCE_THRESHOLD=0.25

# Gaze deviation threshold (normalized 0-1)
GAZE_THRESHOLD=0.3

# ==================== Camera Settings ====================

# Default video source: "0" for webcam, or path/URL for IP camera
VIDEO_SOURCE=0

# Directory to save incident snapshots
OUTPUT_DIR=events_snapshots

# Maximum number of concurrent cameras
MAX_CAMERAS=10

# ==================== Server Settings ====================

# Server host and port
HOST=0.0.0.0
PORT=8000

# Environment mode
ENV=development

# ==================== Model Paths ====================

# YOLO model path (yolo11n.pt for nano, yolo11s.pt for small)
MODEL_PATH=yolo11n.pt

# MediaPipe Face Landmarker model path
FACE_LANDMARKER_PATH=face_landmarker.task

# ==================== Supabase (Production) ====================

# Supabase project URL
SUPABASE_URL=

# Supabase service role key (keep secret!)
SUPABASE_SERVICE_KEY=

# Storage bucket for snapshots
SUPABASE_BUCKET=incident-snapshots